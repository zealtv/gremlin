#!/usr/bin/env bash
# say — local CLI bridge.
#
# Usage:
#   ./.gremlin/say "your message"     # send + wait for reply (default)
#   echo "..." | ./.gremlin/say        # same, message via stdin
#   ./.gremlin/say --repl              # interactive REPL: type, enter, see
#                                      # the reply, repeat. /exit or Ctrl-D
#                                      # to quit. Slash commands work too.
#   ./.gremlin/say --listen            # passive listener: prints each new
#                                      # file in .nest/out/ as it appears
#                                      # and moves it to sent/. Blocks until
#                                      # Ctrl-C. Useful for scheduled
#                                      # outbound and as a side channel.

set -euo pipefail

GREMLIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NEST="$GREMLIN_DIR/.nest"
NESTLING="$NEST/nestling.sh"
OUT="$NEST/out"
SENT="$OUT/sent"
TRANSCRIPT="$GREMLIN_DIR/transcript.md"

TIMEOUT_SECS=60
POLL_SECS=0.5

snapshot_out() {
  local dest="$1"
  if [ -d "$OUT" ]; then
    ( cd "$OUT" && ls -A 2>/dev/null ) | sort > "$dest" || true
  else
    : > "$dest"
  fi
}

print_and_archive() {
  local f="$1"
  cat "$f"
  mkdir -p "$SENT"
  mv "$f" "$SENT/"
}

# --- slash command dispatch ---------------------------------------------
# Intercept /foo-prefixed messages: run commands/foo.sh with the rest as
# args. Bypasses the LLM entirely — slash messages do not append to the
# transcript and do not enter .nest/in/.
if [ "$#" -gt 0 ] && [ "${1#/}" != "$1" ]; then
  rest="$*"
  rest="${rest#/}"
  if [ -z "$rest" ]; then
    echo "usage: $0 /<command> [args...]   (try /help)" >&2
    exit 2
  fi
  cmd="${rest%% *}"
  if [ "$cmd" = "$rest" ]; then
    args=()
  else
    # shellcheck disable=SC2206
    args=(${rest#"$cmd "})
  fi
  COMMANDS="$GREMLIN_DIR/commands"
  script="$COMMANDS/$cmd.sh"
  if [ -x "$script" ]; then
    exec "$script" "${args[@]}"
  fi
  echo "unknown command: /$cmd" >&2
  echo "try /help" >&2
  exit 1
fi

# --- repl mode ----------------------------------------------------------
# Interactive read-eval-print loop. Each turn shells back out to this same
# script, so slash commands and the send-and-wait flow both work unchanged.
if [ "${1:-}" = "--repl" ] || [ "${1:-}" = "-i" ]; then
  echo "(/exit to quit; Ctrl-D works too. slash commands work inline.)"
  while true; do
    if ! IFS= read -r -e -p "> " line; then
      echo
      break
    fi
    [ -z "$line" ] && continue
    case "$line" in
      /exit|/quit) break ;;
    esac
    "$0" "$line" || true
  done
  exit 0
fi

# --- listen mode ---------------------------------------------------------
if [ "${1:-}" = "--listen" ] || [ "${1:-}" = "-l" ]; then
  snapshot="$(mktemp)"
  trap 'rm -f "$snapshot"' EXIT
  snapshot_out "$snapshot"

  while true; do
    for f in "$OUT"/*; do
      [ -f "$f" ] || continue
      base="$(basename "$f")"
      case "$base" in
        *.landing) continue ;;
      esac
      if ! grep -qx -- "$base" "$snapshot"; then
        print_and_archive "$f"
      fi
    done
    sleep "$POLL_SECS"
  done
fi

# --- send + wait mode (default) -----------------------------------------
if [ "$#" -gt 0 ]; then
  msg="$*"
else
  msg="$(cat)"
fi

if [ -z "$msg" ]; then
  echo "usage: $0 <message>   (or pipe via stdin; or --listen)" >&2
  exit 2
fi

snapshot="$(mktemp)"
tmp="$(mktemp)"
trap 'rm -f "$tmp" "$snapshot"' EXIT
snapshot_out "$snapshot"

iso="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
fname_ts="$(date -u +%Y-%m-%dT%H-%M-%SZ)"

# Same single-`>>` rule as tend-loop.sh, same format.
printf '## user — %s\n%s\n\n' "$iso" "$msg" >> "$TRANSCRIPT"

printf '%s\n' "$msg" > "$tmp"
"$NESTLING" ingest "$tmp" "$fname_ts.md" >/dev/null

deadline=$(( $(date +%s) + TIMEOUT_SECS ))
reply=""
while [ "$(date +%s)" -lt "$deadline" ]; do
  for f in "$OUT"/*; do
    [ -f "$f" ] || continue
    base="$(basename "$f")"
    case "$base" in
      *.landing) continue ;;
    esac
    if ! grep -qx -- "$base" "$snapshot"; then
      reply="$f"
      break 2
    fi
  done
  sleep "$POLL_SECS"
done

if [ -z "$reply" ]; then
  echo "say: no reply within ${TIMEOUT_SECS}s" >&2
  exit 1
fi

print_and_archive "$reply"
