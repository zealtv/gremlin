#!/usr/bin/env bash
# say — local CLI bridge.
#
# Usage: ./.gremlin/say "your message"
#        echo "your message" | ./.gremlin/say
#
# Appends a `## user` turn to transcript.md, drops the message into .nest/in/
# for the tend loop, then waits up to 60s for a reply to land in .nest/out/.
# Prints the reply and moves it to .nest/out/sent/ so it isn't reprinted.

set -euo pipefail

GREMLIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NEST="$GREMLIN_DIR/.nest"
NESTLING="$NEST/nestling.sh"
OUT="$NEST/out"
SENT="$OUT/sent"
TRANSCRIPT="$GREMLIN_DIR/transcript.md"

TIMEOUT_SECS=60
POLL_SECS=0.5

if [ "$#" -gt 0 ]; then
  msg="$*"
else
  msg="$(cat)"
fi

if [ -z "$msg" ]; then
  echo "usage: $0 <message>   (or pipe via stdin)" >&2
  exit 2
fi

# Snapshot existing out/ filenames so we ignore replies from prior sessions.
snapshot="$(mktemp)"
tmp="$(mktemp)"
trap 'rm -f "$tmp" "$snapshot"' EXIT

if [ -d "$OUT" ]; then
  ( cd "$OUT" && ls -A 2>/dev/null ) | sort > "$snapshot" || true
fi

iso="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
fname_ts="$(date -u +%Y-%m-%dT%H-%M-%SZ)"

# Same single-`>>` rule as tend-loop.sh, same format.
printf '## user — %s\n%s\n\n' "$iso" "$msg" >> "$TRANSCRIPT"

printf '%s\n' "$msg" > "$tmp"
"$NESTLING" ingest "$tmp" "$fname_ts.md" >/dev/null

# Wait for a reply: a file in OUT whose name isn't in the snapshot and
# isn't a `.landing` placeholder.
deadline=$(( $(date +%s) + TIMEOUT_SECS ))
reply=""
while [ "$(date +%s)" -lt "$deadline" ]; do
  for f in "$OUT"/*; do
    [ -f "$f" ] || continue
    base="$(basename "$f")"
    case "$base" in
      *.landing) continue ;;
    esac
    if ! grep -qx -- "$base" "$snapshot"; then
      reply="$f"
      break 2
    fi
  done
  sleep "$POLL_SECS"
done

if [ -z "$reply" ]; then
  echo "say: no reply within ${TIMEOUT_SECS}s" >&2
  exit 1
fi

cat "$reply"
mkdir -p "$SENT"
mv "$reply" "$SENT/"
