# web bridge config — copy to `config` and edit. All values are optional in M0;
# the defaults below serve a loopback-only, read-only transcript window.
#
#   cp config.example config

# Address to bind. Keep this on loopback. A non-loopback bind is a loud,
# token-gated, off-by-default opt-in handled by a later stitch (spec §17).
WEB_BIND=127.0.0.1

# Port to listen on. Leave it unset (the default) and the bridge auto-assigns a
# free port on first start — derived from this gremlin's host-dir name so each
# gremlin on a shared machine gets its own stable number — then pins it back into
# the runtime `config` so it persists across restarts, reboots, and `/update`.
# Set it explicitly to override; an explicit port already in use fails loud (no
# auto-bump).
# WEB_PORT=8787

# Remote access (off by default). A non-loopback WEB_BIND (e.g. a tailnet IP)
# REQUIRES a token or the bridge refuses to start. Every request must then
# present it — open the page once as /?t=<token> (it sets a session cookie) or
# send an X-Web-Token header. Traffic is cleartext unless tunneled; an SSH
# tunnel / WireGuard / Tailscale is the safer path. Generate a token with e.g.
#   python3 -c 'import secrets;print(secrets.token_urlsafe(18))'
# WEB_REMOTE_TOKEN=
#
# Optional: extra Host header(s) to accept when bound remotely (comma-separated),
# e.g. a MagicDNS name. The bind address itself is always accepted.
# WEB_REMOTE_HOST=

# Reserved for attachments (a later stitch): per-file/per-body upload cap.
# WEB_MAX_UPLOAD=26214400
